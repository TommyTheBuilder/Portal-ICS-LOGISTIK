# ---------- App ----------
PORT=3000
CORS_ORIGIN=https://portal.example.com,https://container.example.com

# Falls Cookies cross-site gesendet werden sollen, darf CORS_ORIGIN nicht "*" sein.
# Frontend muss fetch(..., { credentials: "include" }) setzen.

# ---------- Existing admin permission auth (server-side) ----------
# Permission key used to authorize container routes
ADMIN_PERMISSION_KEY=integration.container_login

# Dedicated DB URL for reading session + permission data
ADMIN_AUTH_DATABASE_URL=postgresql://user:password@db-host:5432/admin_auth

# Session cookie name issued by the upstream auth system
ADMIN_SESSION_COOKIE_NAME=connect.sid

# Optional custom query. If empty, the backend uses the default users -> user_roles -> role_permissions -> permissions query.
# Must accept two positional params:
#   $1 = user_id from resolved session
#   $2 = permission key (ADMIN_PERMISSION_KEY)
ADMIN_AUTH_QUERY=

# ---------- Cookie attributes (set by your auth/session issuer) ----------
# Ensure the upstream service sets session cookies compatible with your deployment:
# - SameSite=None for cross-site requests
# - Secure=true for HTTPS
# - Domain=.example.com if multiple subdomains must share the cookie
# Example (configuration belongs to the service that creates the session cookie):
# SESSION_COOKIE_SAMESITE=None
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_DOMAIN=.example.com

# Cookie issued by this portal backend (for subdomain sharing)
AUTH_COOKIE_NAME=portal_auth
AUTH_COOKIE_DOMAIN=.paletten-ms.de
AUTH_COOKIE_SAME_SITE=None
AUTH_COOKIE_MAX_AGE_SECONDS=43200
